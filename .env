# Application
APP_NAME="Competitive Intelligence Scraper"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20

# Cache TTL (seconds)
CACHE_TTL_PRICING=3600
CACHE_TTL_PRODUCT=7200
CACHE_TTL_SEARCH=1800

# Scraper
MAX_CONCURRENT_SCRAPERS=10
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=2.0

# Rate limiting (per domain)
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW=10
